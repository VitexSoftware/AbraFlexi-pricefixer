{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
  "schemaVersion": "3.4.0",
  "uuid": "d88ddeec-6652-4563-b0d9-fa2a2b06b84e",
  "name": {
    "en": "Stock Price Fixer",
    "cs": "Opravovač skladových cen"
  },
  "description": {
    "en": "Copy last warehouse price (posledCena) to purchase price (nakupCena) for all non-bundle products in AbraFlexi",
    "cs": "Zkopíruje poslední skladovou cenu (posledCena) do nákupní ceny (nakupCena) pro všechny nesadové produkty v AbraFlexi"
  },
  "tags": [
    "AbraFlexi",
    "Price",
    "Fixer",
    "Stock"
  ],
  "homepage": "https://github.com/VitexSoftware/AbraFlexi-pricefixer",
  "image": "",
  "ociimage": "docker.io/vitexsoftware/abraflexi-pricefixer",
  "executable": "abraflexi-pricefixer-stock",
  "events": {
    "emits": {
      "price.updated": {
        "description": "Purchase price records were updated from warehouse last price"
      }
    }
  },
  "environment": {
    "ABRAFLEXI_COMPANY": {
      "type": "string",
      "description": "",
      "defval": "demo_de",
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login",
        "cs": "AbraFlexi Login"
      },
      "defval": "winstrom",
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
      "description": {
        "en": "AbraFlexi password",
        "cs": "AbraFlexi heslo"
      },
      "defval": "winstrom",
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URI",
        "cs": "AbraFlexi Server URI"
      },
      "defval": "https://demo.flexibee.eu:5434",
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_GROUP": {
      "type": "string",
      "description": {
        "en": "Group of Goods that identifies bundles (skipped by this command)",
        "cs": "Skupina zboží označující sady (přeskočeny tímto příkazem)"
      },
      "defval": "code:SADA",
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_WAREHOUSE": {
      "type": "string",
      "description": {
        "en": "Warehouse code to read last price from",
        "cs": "Kód skladu, ze kterého se čte poslední cena"
      },
      "defval": "code:SKLAD-DS",
      "required": false,
      "category": "API"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "zapisovat log zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    }
  }
}
