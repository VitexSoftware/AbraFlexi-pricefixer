#!/usr/bin/make -f
# You must remove unused comment lines for the released package.
#export DH_VERBOSE = 1
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed

%:
	dh $@ --with phpcomposer

override_dh_auto_build:
	# Generate custom Debian autoloader for application
	cat > debian/autoload.php <<'AUTOLOADER'
	<?php
	// Debian autoloader for abraflexi-pricefixer
	require_once '/usr/share/php/AbraFlexi/autoload.php';
	// PSR-4 autoloader for application classes
	spl_autoload_register(function (string $$class): void {
	    if (strncmp('AbraFlexi\\PriceFix\\', $$class, 20) === 0) {
	        $$file = '/usr/share/abraflexi-pricefixer/PriceFix/' . str_replace('\\', '/', substr($$class, 20)) . '.php';
	        if (file_exists($$file)) { require $$file; }
	    }
	});
	AUTOLOADER

override_dh_install:
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  debian/composer.json |sponge debian/tmp/composer.json
	dh_install
	# Install Debian autoloader
	install -D -m 0644 debian/autoload.php debian/abraflexi-pricefixer/usr/share/php/abraflexi-pricefixer/autoload.php
	sed -i -e 's/\.\.\/vendor/\/usr\/share\/php\/abraflexi-pricefixer/g'   debian/abraflexi-pricefixer/usr/share/abraflexi-pricefixer/*.php
	sed -i -e 's/\.\.\/.env//'                                          debian/abraflexi-pricefixer/usr/share/abraflexi-pricefixer/*.php
	sed -i -e 's/\.\.\/i18n/\/usr\/share\/locale/g'                   debian/abraflexi-pricefixer/usr/share/abraflexi-pricefixer/*.php
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  debian/multiflexi-abraflexi-pricefixer/usr/lib/abraflexi-pricefixer/multiflexi/price_fixer.multiflexi.app.json | sponge debian/multiflexi-abraflexi-pricefixer/usr/lib/abraflexi-pricefixer/multiflexi/price_fixer.multiflexi.app.json

